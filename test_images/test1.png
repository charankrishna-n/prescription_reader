<li data-section-id="1cborz0" data-start="964" data-end="980">
<p data-start="966" data-end="980">Load dataset</p>
</li>
<li data-section-id="1if5rgs" data-start="981" data-end="1011">
<p data-start="983" data-end="1011">Convert images → grayscale</p>
</li>
<li data-section-id="2bpn3i" data-start="1012" data-end="1029">
<p data-start="1014" data-end="1029">Resize images</p>
</li>
<li data-section-id="igbmi3" data-start="1030" data-end="1043">
<p data-start="1032" data-end="1043">Train CNN</p>
</li>
</ul>
