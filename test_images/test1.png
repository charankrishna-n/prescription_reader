<span>,</span><span class="ͼq">28</span><span>,</span><span class="ͼq">28</span><span>,</span><span class="ͼq">1</span><span>)</span><br><br><span class="ͼt">pred</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">model</span><span class="ͼn">.</span><span>predict(</span><span class="ͼt">img</span><span>)</span><br><span class="ͼt">print</span><span>(</span><span class="ͼt">pred</span><span class="ͼn">.</span><span>argmax())</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
