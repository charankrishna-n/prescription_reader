<li data-section-id="7eso9h" data-start="1031" data-end="1132">
<p data-start="1033" data-end="1039">Store:</p>
<ul data-start="1044" data-end="1132">
<li data-section-id="1gulflj" data-start="1044" data-end="1071">
<p data-start="1046" data-end="1071">Extracted prescriptions</p>
</li>
<li data-section-id="1efyjyd" data-start="1076" data-end="1107">
<p data-start="1078" data-end="1107">Patient medication schedule</p>
</li>
<li data-section-id="1b3ukv9" data-start="1112" data-end="1132">
<p data-start="1114" data-end="1132">Reminder timings</p>
</li>
</ul>
</li>
</ul>
</li>
<li data-section-id="196bq5f" data-start="1134" data-end="1196">
<p data-start="1136" data-end="1145">Optional:</p>
<ul data-start="1148" data-end="1196">
