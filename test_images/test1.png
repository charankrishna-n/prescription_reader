<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="1637" data-end="1755" class="w-fit min-w-(--thread-content-width)"><thead data-start="1637" data-end="1660"><tr data-start="1637" data-end="1660"><th data-start="1637" data-end="1648" data-col-size="sm" class="">You Want</th><th data-start="1648" data-end="1660" data-col-size="sm" class="">Use This</th></tr></thead><tbody data-start="1681" data-end="1755"><tr data-start="1681" data-end="1712"><td data-start="1681" data-end="1699" data-col-size="sm">Quick hackathon</td><td data-start="1699" data-end="1712" data-col-size="sm">✅ API Key</td></tr><tr data-start="1713" data-end="1755"><td data-start="1713" data-end="1733" data-col-size="sm">Secure production</td><td data-start="1733" data-end="1755" data-col-size="sm">🔐 Service Account</td></tr></tbody></table><div class="sticky h-0 select-none end-(--thread-content-margin) self-end"><div class="absolute end-0 flex items-end" style="height: 33px;"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-cohbnghc.svg#ce3544" fill="currentColor"></use></svg></button></span></div></div></div></div>
