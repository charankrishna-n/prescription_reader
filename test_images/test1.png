<pre class="overflow-visible! px-0!" data-start="690" data-end="1716"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-cohbnghc.svg#e45ab3" fill="currentColor"></use></svg>Python</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-cohbnghc.svg#ce3544" fill="currentColor"></use></svg></button><button class="btn relative group-focus-within/dialog:focus-visible:[outline-width:1.5px] group-focus-within/dialog:focus-visible:[outline-offset:2.5px] group-focus-within/dialog:focus-visible:[outline-style:solid] group-focus-within/dialog:focus-visible:[outline-color:var(--text-primary)] btn-ghost border-token-border-default ms-2 border font-sans" aria-label="Run code" type="button"><div class="flex w-full items-center justify-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-label="" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-cohbnghc.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">import</span><span> </span><span class="ͼt">cv2</span><br><span class="ͼn">import</span><span> </span><span class="ͼt">numpy</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">np</span><br><span class="ͼn">import</span><span> </span><span class="ͼt">matplotlib</span><span class="ͼn">.</span><span class="ͼt">pyplot</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">plt</span><br><br><span class="ͼl"># Load image</span><br><span class="ͼt">img</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>imread(</span><span class="ͼr">"test.png"</span><span>)</span><br><span class="ͼt">gray</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>cvtColor(</span><span class="ͼt">img</span><span>, </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>COLOR_BGR2GRAY)</span><br><br><span class="ͼl"># Improve contrast</span><br><span class="ͼt">gray</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>GaussianBlur(</span><span class="ͼt">gray</span><span>, (</span><span class="ͼq">5</span><span>,</span><span class="ͼq">5</span><span>), </span><span class="ͼq">0</span><span>)</span><br><br><span class="ͼl"># Adaptive threshold (VERY IMPORTANT)</span><br><span class="ͼt">thresh</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>adaptiveThreshold(</span><br><span>    </span><span class="ͼt">gray</span><span>, </span><span class="ͼq">255</span><span>,</span><br><span>    </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>ADAPTIVE_THRESH_GAUSSIAN_C,</span><br><span>    </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>THRESH_BINARY_INV,</span><br><span>    </span><span class="ͼq">11</span><span>, </span><span class="ͼq">2</span><br><span>)</span><br><br><span class="ͼl"># Find contours</span><br><span class="ͼt">contours</span><span>, </span><span class="ͼt">_</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>findContours(</span><span class="ͼt">thresh</span><span>, </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>RETR_EXTERNAL, </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>CHAIN_APPROX_SIMPLE)</span><br><br><span class="ͼt">print</span><span>(</span><span class="ͼr">"Total contours found:"</span><span>, </span><span class="ͼt">len</span><span>(</span><span class="ͼt">contours</span><span>))</span><br><br><span class="ͼl"># Draw bounding boxes</span><br><span class="ͼt">output</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">img</span><span class="ͼn">.</span><span>copy()</span><br><br><span class="ͼt">boxes</span><span> </span><span class="ͼn">=</span><span> []</span><br><br><span class="ͼn">for</span><span> </span><span class="ͼt">cnt</span><span> </span><span class="ͼn">in</span><span> </span><span class="ͼt">contours</span><span>:</span><br><span>    </span><span class="ͼt">x</span><span>, </span><span class="ͼt">y</span><span>, </span><span class="ͼt">w</span><span>, </span><span class="ͼt">h</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>boundingRect(</span><span class="ͼt">cnt</span><span>)</span><br><br><span>    </span><span class="ͼl"># Filter noise (VERY IMPORTANT)</span><br><span>    </span><span class="ͼn">if</span><span> </span><span class="ͼt">w</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">10</span><span> </span><span class="ͼn">and</span><span> </span><span class="ͼt">h</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">10</span><span>:</span><br><span>        </span><span class="ͼt">boxes</span><span class="ͼn">.</span><span>append((</span><span class="ͼt">x</span><span>, </span><span class="ͼt">y</span><span>, </span><span class="ͼt">w</span><span>, </span><span class="ͼt">h</span><span>))</span><br><span>        </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>rectangle(</span><span class="ͼt">output</span><span>, (</span><span class="ͼt">x</span><span>,</span><span class="ͼt">y</span><span>), (</span><span class="ͼt">x</span><span class="ͼn">+</span><span class="ͼt">w</span><span>, </span><span class="ͼt">y</span><span class="ͼn">+</span><span class="ͼt">h</span><span>), (</span><span class="ͼq">0</span><span>,</span><span class="ͼq">255</span><span>,</span><span class="ͼq">0</span><span>), </span><span class="ͼq">2</span><span>)</span><br><br><span class="ͼl"># Sort left to right</span><br><span class="ͼt">boxes</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">sorted</span><span>(</span><span class="ͼt">boxes</span><span>, </span><span class="ͼt">key</span><span class="ͼn">=lambda</span><span> </span><span class="ͼt">b</span><span>: </span><span class="ͼt">b</span><span>[</span><span class="ͼq">0</span><span>])</span><br><br><span class="ͼl"># Show result</span><br><span class="ͼt">plt</span><span class="ͼn">.</span><span>figure(</span><span class="ͼt">figsize</span><span class="ͼn">=</span><span>(</span><span class="ͼq">10</span><span>,</span><span class="ͼq">6</span><span>))</span><br><span class="ͼt">plt</span><span class="ͼn">.</span><span>imshow(</span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>cvtColor(</span><span class="ͼt">output</span><span>, </span><span class="ͼt">cv2</span><span class="ͼn">.</span><span>COLOR_BGR2RGB))</span><br><span class="ͼt">plt</span><span class="ͼn">.</span><span>title(</span><span class="ͼr">"Detected Characters"</span><span>)</span><br><span class="ͼt">plt</span><span class="ͼn">.</span><span>axis(</span><span class="ͼr">"off"</span><span>)</span><br><span class="ͼt">plt</span><span class="ͼn">.</span><span>show()</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
